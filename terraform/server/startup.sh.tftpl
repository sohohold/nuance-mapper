#!/bin/bash
# @sacloud-once
# @sacloud-desc nuance-mapper: Node.js セットアップとアプリの常駐起動
# @sacloud-require-archive distro-ubuntu
#
# このスクリプトはサーバの初回起動時に一度だけ root で実行される。
# 進行状況は /var/log/nuance-mapper-setup.log で確認できる。
set -euxo pipefail
exec > /var/log/nuance-mapper-setup.log 2>&1

export DEBIAN_FRONTEND=noninteractive
apt-get update -y
apt-get install -y git curl ca-certificates

# Node.js 24 (NodeSource) と pnpm — Vercel の Node.js バージョンに合わせる
curl -fsSL https://deb.nodesource.com/setup_24.x | bash -
apt-get install -y nodejs
npm install -g pnpm

# アプリ実行用ユーザー
useradd --system --create-home --shell /usr/sbin/nologin app || true

# アプリ取得
git clone --branch "${repo_branch}" "${repo_url}" /opt/nuance-mapper

# LLM プロバイダのAPIキーはこのスクリプトに書き込まない
# (sakura_script の内容および Terraform state に平文で残ってしまうため)。
# 空のままでもアプリはモックデータで動作する。使う場合はデプロイ後にSSHして
# 手動で設定する: sudo -u app vi /opt/nuance-mapper/.env.local && sudo systemctl restart nuance-mapper
touch /opt/nuance-mapper/.env.local
chown -R app:app /opt/nuance-mapper
chmod 600 /opt/nuance-mapper/.env.local

# 依存インストールとプロダクションビルド
cd /opt/nuance-mapper
sudo -u app -H pnpm install --frozen-lockfile
sudo -u app -H pnpm build

# next.config.ts の output: "standalone" により `.next/standalone/server.js` が生成される。
# standalone 出力には public/ と .next/static が含まれないため、手動でコピーする。
# (`next start` は standalone ビルドでは動作しないため使わない)
sudo -u app -H cp -r public .next/standalone/public
sudo -u app -H cp -r .next/static .next/standalone/.next/static

# systemd で常駐化（ポート80で待ち受け。非rootでも80を使えるよう capability を付与）
cat > /etc/systemd/system/nuance-mapper.service <<'UNITEOF'
[Unit]
Description=nuance-mapper (Next.js)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=app
WorkingDirectory=/opt/nuance-mapper/.next/standalone
Environment=PORT=80
Environment=HOSTNAME=0.0.0.0
EnvironmentFile=/opt/nuance-mapper/.env.local
ExecStart=/usr/bin/node server.js
Restart=on-failure
RestartSec=5
AmbientCapabilities=CAP_NET_BIND_SERVICE

[Install]
WantedBy=multi-user.target
UNITEOF

systemctl daemon-reload
systemctl enable --now nuance-mapper
