# このファイルを terraform.tfvars にコピーして値を埋める:
#   cp terraform.tfvars.example terraform.tfvars
# terraform.tfvars は .gitignore 済み（秘密情報を含むためコミットしない）

# 必須: SSH公開鍵（`cat ~/.ssh/id_ed25519.pub` の出力を貼り付ける）
ssh_public_key = "ssh-ed25519 AAAA... you@example.com"

# 任意: ゾーンやスペックの変更
# zone      = "is1b"   # is1a / is1b / tk1a / tk1b
# core      = 2
# memory    = 4        # GiB
# disk_size = 20       # GiB

# 任意: デプロイするブランチ
# repo_branch = "main"

# LLM プロバイダのAPIキーはここでは設定しない。
# Terraform state に平文で残ってしまうため、デプロイ後にSSHして
# /opt/nuance-mapper/.env.local を手動編集する(README参照)。
# 未設定でもアプリはモックデータで動作する。
