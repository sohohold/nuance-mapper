# このファイルを backend.hcl にコピーして使う:
#   cp backend.hcl.example backend.hcl
#   terraform init -backend-config=backend.hcl
# backend.hcl は .gitignore 済み（bucket名は環境ごとに変わるためコミットしない）
#
# bucket は事前に一度だけ手動で作成しておく必要がある(下記READMEの「事前準備」参照)。
# 認証情報(アクセスキー/シークレット)はここには書かず、環境変数で渡す:
#   export AWS_ACCESS_KEY_ID="オブジェクトストレージのアクセスキー"
#   export AWS_SECRET_ACCESS_KEY="オブジェクトストレージのシークレットキー"

bucket = "your-unique-tfstate-bucket-name"
key    = "nuance-mapper/apprun/terraform.tfstate"
region = "jp-north-1"
endpoints = {
  s3 = "https://s3.isk01.sakurastorage.jp"
}
skip_credentials_validation = true
skip_region_validation      = true
skip_requesting_account_id  = true
skip_metadata_api_check     = true
skip_s3_checksum            = true
use_path_style               = true
