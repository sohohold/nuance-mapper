# ── LLM providers (all optional — set any subset; unset ones are skipped) ──
# Each provider has its own independent free-tier daily quota, so setting
# more keys directly increases availability at $0. Ladder order:
# Gemini → Groq → Cerebras → OpenRouter (openai/gpt-oss-120b:free only).
# For Gemini/Groq/Cerebras the fastest currently-served model is picked
# at runtime from a preference list via the provider's /models endpoint.
# To guarantee $0, use keys from accounts WITHOUT billing enabled —
# billing-enabled accounts can be charged beyond the free tier.

# Google AI Studio (no credit card required): https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq (no credit card required): https://console.groq.com/keys
GROQ_API_KEY=

# Cerebras (no credit card required): https://cloud.cerebras.ai/
CEREBRAS_API_KEY=

# OpenRouter: https://openrouter.ai/settings/keys
# Note: all :free models share one per-account daily pool (50 req/day,
# or 1000 req/day after a one-time purchase of $10+ in credits).
OPENROUTER_API_KEY=

# ── Persistent cache (optional but recommended for serverless deploys) ──
# Upstash Redis REST credentials (free tier is plenty). Vercel KV names
# (KV_REST_API_URL / KV_REST_API_TOKEN) are also accepted.
# Without these, the cache falls back to per-instance memory + local disk.
# Entries expire 30 days after generation.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
